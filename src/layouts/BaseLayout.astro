---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';
import { pub } from '../utils/asset';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  noIndex?: boolean;
  bodyClass?: string;
}

const {
  title,
  description = 'KA.architecten ontwerpt particuliere woningen, verbouwingen en utiliteitsbouw vanuit Tilburg, voor heel Noord-Brabant.',
  ogImage = 'https://www.ka-architecten.nl/images/zeist-2.webp',
  canonical,
  noIndex = false,
  bodyClass = '',
} = Astro.props;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const gaId = import.meta.env.PUBLIC_GA_ID ?? '';
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="nl_NL" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="KA.architecten" />
    <meta name="twitter:card" content="summary_large_image" />

    <meta name="author" content="Peter Keijsers" />
    <meta name="geo.region" content="NL-NB" />
    <meta name="geo.placename" content="Tilburg, Noord-Brabant" />
    <meta name="geo.position" content="51.5556;5.0913" />
    <meta name="ICBM" content="51.5556, 5.0913" />

    <link rel="icon" href={pub('/favicon.svg')} type="image/svg+xml" />
    <meta name="theme-color" content="#f5f3ef" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=IBM+Plex+Mono:wght@400&display=swap" rel="stylesheet" />

    <ViewTransitions />
    <slot name="head" />

    {gaId && <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`} is:inline></script>}
    {gaId && <script is:inline set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments)}gtag('js',new Date());gtag('config','${gaId}');`}></script>}
  </head>
  <body class={bodyClass}>
    <Header />
    <slot />
    <Footer />

    <script src={pub('/js/site.js')} is:inline></script>
  </body>
</html>
