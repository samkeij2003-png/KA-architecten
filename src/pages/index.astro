---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { projects } from '../data/projects';
import { pub } from '../utils/asset';
import { getImg } from '../utils/images';

import zeist2Img from '../assets/images/zeist-2.webp';
import zeistTrapImg from '../assets/images/zeist-trap.webp';

const featured = projects.find(p => p.slug === 'betonnen-woonhuis-zeist')!;
const grid = projects.filter(p => p.slug !== 'betonnen-woonhuis-zeist').slice(0, 6);
const gridCovers = await Promise.all(grid.map(p => getImg(p.cover)));
---

<BaseLayout
  title="KA.architecten | Architectenbureau Tilburg & Noord-Brabant"
  description="KA.architecten is het architectenbureau van Peter Keijsers in Tilburg, werkzaam in heel Noord-Brabant. Ruim 30 jaar ervaring in woningontwerp, verbouwing en utiliteitsbouw."
  bodyClass="home"
>
  <script type="application/ld+json" slot="head">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "ProfessionalService"],
    "name": "KA.architecten",
    "url": "https://www.ka-architecten.nl/",
    "telephone": "+31621231821",
    "email": "p.keijsers@ka-architecten.nl",
    "founder": "Peter Keijsers",
    "description": "Architectuurbureau voor particuliere woningen, verbouwing en utiliteitsbouw, gevestigd in Tilburg.",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Ankeveenstraat 44",
      "postalCode": "5036 CB",
      "addressLocality": "Tilburg",
      "addressRegion": "Noord-Brabant",
      "addressCountry": "NL"
    }
  })}</script>

  <!-- HERO -->
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero-image">
      <Image
        src={zeist2Img}
        alt="Betonnen woonhuis in Zeist — KA.architecten"
        fetchpriority="high"
        width={1920}
        format="webp"
        quality={85}
      />
    </div>
    <div class="hero-veil"></div>
    <div class="hero-content">
      <p class="eyebrow" style="font-size: 12px; letter-spacing: 0.16em;">Architectuur als ambacht · Tilburg</p>
      <h1 id="hero-title">
        <span class="amark">KA</span>.architecten
      </h1>
      <div class="hero-meta">
        <span>Ruim 30 jaar ervaring</span>
        <span>Particuliere woningen</span>
        <span>Verbouwing &amp; transformatie</span>
        <span>Utiliteitsbouw</span>
      </div>
    </div>
  </section>

  <!-- INTRO -->
  <section class="section" style="padding-top: clamp(32px, 4vw, 56px); padding-bottom: 48px;">
    <div class="container split-2">
      <div>
        <p class="eyebrow">Bureau</p>
      </div>
      <div>
        <p class="lead">
          Wij zijn gevestigd in Tilburg en werkzaam in heel Brabant. Met ruim 30 jaar ervaring ontwerpen wij woningen, verbouwingen en utiliteitsgebouwen, sober van opzet en met aandacht voor materiaal en context.
        </p>
        <p class="body-text" style="margin-top: 28px;">
          Architectuur als ambacht: het scheppen van ruimte met eerlijke materialen en zorgvuldige details. Ruimten waarin je prettig woont.
        </p>
        <p style="margin-top: 28px;"><a class="link-arrow" href={pub('/bureau')}>Lees meer over het bureau →</a></p>
      </div>
    </div>
  </section>

  <!-- UITGELICHT PROJECT -->
  <section class="featured hairline" style="padding-top: 0;">
    <a href={pub(`/projecten/${featured.slug}`)} aria-label={`Uitgelicht: ${featured.title} ${featured.location}`}>
      <div class="featured-media">
        <Image
          src={zeistTrapImg}
          alt="Centrale betonnen trap — Betonnen woonhuis Zeist"
          loading="lazy"
          width={1400}
          format="webp"
          quality={85}
        />
      </div>
      <div class="container">
        <div class="featured-meta">
          <div>
            <p class="eyebrow">Uitgelicht project</p>
            <h2 style="margin-top: 6px;">Betonnen woonhuis · Zeist</h2>
          </div>
          <p class="text-stone" style="font-size: 14px;">
            Een sculpturale woning in zichtbeton, hout en glas.
            <span style="border-bottom: 1px solid var(--ink); color: var(--ink);">Bekijk project →</span>
          </p>
        </div>
      </div>
    </a>
  </section>

  <!-- PROJECTEN GRID -->
  <section class="section">
    <div class="container">
      <div class="projects-toolbar">
        <p class="eyebrow">Geselecteerde projecten</p>
        <a class="link-arrow" href={pub('/projecten')}>Alle projecten →</a>
      </div>
      <div class="projects-grid">
        {grid.map((p, i) => (
          <a class="project-card" href={pub(`/projecten/${p.slug}`)} aria-label={`Project: ${p.title}, ${p.location}`}>
            <div class="project-media">
              <Image
                src={gridCovers[i]}
                alt={`${p.title}, ${p.location}`}
                loading="lazy"
                width={800}
                format="webp"
                quality={85}
              />
              <div class="project-overlay">
                <span class="name">{p.title}</span>
                <span class="loc">{p.location}{p.status === 'In uitvoering' ? ' · in uitvoering' : ''}</span>
              </div>
            </div>
            <div class="project-meta">
              <span class="name">{p.title}</span>
              <span class="loc">{p.location}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- USP -->
  <section class="section hairline">
    <div class="container split-2">
      <div><p class="eyebrow">Werkwijze</p></div>
      <div class="usp-row" style="border-top: 0; padding-top: 0;">
        <div class="usp">
          <h4>Eén aanspreekpunt</h4>
          <p>Van schetsontwerp tot oplevering werkt u rechtstreeks met Peter Keijsers. Korte lijnen, persoonlijk, betrokken.</p>
        </div>
        <div class="usp">
          <h4>Plek &amp; programma</h4>
          <p>Ieder ontwerp begint met een grondige analyse van de locatie en de wensen van de bewoner. Het ontwerp volgt de plek, niet andersom.</p>
        </div>
        <div class="usp">
          <h4>Eerlijk materiaal</h4>
          <p>Hout · baksteen · beton · glas. Materialen die mooier worden met de jaren en passen bij het ambacht.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
