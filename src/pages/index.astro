---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/projects';

const featured = projects.find(p => p.slug === 'betonnen-woonhuis-zeist')!;
const grid = projects.filter(p => p.slug !== 'betonnen-woonhuis-zeist').slice(0, 6);
---

<BaseLayout
  title="KA.architecten — Architect Peter Keijsers · Tilburg & Noord-Brabant"
  description="KA.architecten is het bureau van architect Peter Keijsers. Ruim 30 jaar ervaring met woningontwerp, verbouwing en utiliteitsbouw in Tilburg en Noord-Brabant."
  bodyClass="home"
>
  <link rel="preload" slot="head" as="image" href="/images/zeist-2.jpg" />
  <script type="application/ld+json" slot="head">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "ProfessionalService"],
    "name": "KA.architecten",
    "url": "https://www.ka-architecten.nl/",
    "telephone": "+31621231821",
    "email": "p.keijsers@ka-architecten.nl",
    "founder": "Peter Keijsers",
    "description": "Architectuurbureau voor particuliere woningen, verbouwing en utiliteitsbouw, gevestigd in Tilburg.",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Ankeveenstraat 44",
      "postalCode": "5036 CB",
      "addressLocality": "Tilburg",
      "addressRegion": "Noord-Brabant",
      "addressCountry": "NL"
    }
  })}</script>

  <!-- HERO -->
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero-image">
      <img src="/images/zeist-2.jpg" alt="Betonnen woonhuis in Zeist — KA.architecten" fetchpriority="high" />
    </div>
    <div class="hero-veil"></div>
    <div class="hero-content">
      <p class="eyebrow">Architectuur als ambacht · Tilburg</p>
      <h1 id="hero-title">
        <span class="amark">KA</span>.architecten<br />
        woningen die blijven, in Brabant en daarbuiten.
      </h1>
      <div class="hero-meta">
        <span>Ruim 30 jaar ervaring</span>
        <span>Particuliere woningen</span>
        <span>Verbouwing &amp; transformatie</span>
        <span>Utiliteitsbouw</span>
      </div>
    </div>
  </section>

  <!-- INTRO -->
  <section class="section">
    <div class="container split-2">
      <div>
        <p class="eyebrow">Bureau</p>
      </div>
      <div>
        <p class="lead">
          KA.architecten is het bureau van architect <strong>Peter Keijsers</strong>, gevestigd in Tilburg en werkzaam in heel Noord-Brabant. Peter heeft ruim 30 jaar ervaring in architectuur en ontwerpt woningen, verbouwingen en utiliteitsgebouwen, sober van opzet en met aandacht voor materiaal en context.
        </p>
        <p class="body-text" style="margin-top: 28px;">
          Architectuur als ambacht: eerlijke materialen, zorgvuldige details, ruimtes die mooier worden met de tijd. Elk project begint met de plek en de bewoner. Daaruit volgt het ontwerp, niet andersom.
        </p>
        <p style="margin-top: 28px;"><a class="link-arrow" href="/bureau">Lees meer over het bureau →</a></p>
      </div>
    </div>
  </section>

  <!-- UITGELICHT PROJECT -->
  <section class="featured hairline" style="padding-top: 0;">
    <a href={`/projecten/${featured.slug}`} aria-label={`Uitgelicht: ${featured.title} ${featured.location}`}>
      <div class="featured-media">
        <img src="/images/zeist-trap.jpg" alt="Centrale betonnen trap — Betonnen woonhuis Zeist" loading="lazy" />
      </div>
      <div class="container">
        <div class="featured-meta">
          <div>
            <p class="eyebrow">Uitgelicht project</p>
            <h2 style="margin-top: 6px;">Betonnen woonhuis · Zeist</h2>
          </div>
          <p class="text-stone" style="font-size: 14px;">
            Een sculpturale woning in zichtbeton, hout en glas.
            <span style="border-bottom: 1px solid var(--ink); color: var(--ink);">Bekijk project →</span>
          </p>
        </div>
      </div>
    </a>
  </section>

  <!-- PROJECTEN GRID -->
  <section class="section">
    <div class="container">
      <div class="projects-toolbar">
        <p class="eyebrow">Geselecteerde projecten</p>
        <a class="link-arrow" href="/projecten">Alle projecten →</a>
      </div>
      <div class="projects-grid">
        {grid.map(p => (
          <a class="project-card" href={`/projecten/${p.slug}`} aria-label={`Project: ${p.title}, ${p.location}`}>
            <div class="project-media">
              <img src={p.cover} alt={`${p.title}, ${p.location}`} loading="lazy" />
              <div class="project-overlay">
                <span class="name">{p.title}</span>
                <span class="loc">{p.location}{p.status === 'In uitvoering' ? ' · in uitvoering' : ''}</span>
              </div>
            </div>
            <div class="project-meta">
              <span class="name">{p.title}</span>
              <span class="loc">{p.location}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- USP -->
  <section class="section hairline">
    <div class="container">
      <p class="eyebrow mb-md">Werkwijze</p>
      <div class="usp-row">
        <div class="usp">
          <h4>Eén aanspreekpunt</h4>
          <p>Van schetsontwerp tot oplevering werkt u rechtstreeks met Peter Keijsers. Korte lijnen, persoonlijk, betrokken.</p>
        </div>
        <div class="usp">
          <h4>Plek &amp; programma</h4>
          <p>Ieder ontwerp begint met een grondige analyse van de locatie en de wensen van de bewoner. Het ontwerp volgt de plek, niet andersom.</p>
        </div>
        <div class="usp">
          <h4>Materiaal als taal</h4>
          <p>Eerlijk hout, baksteen, beton en glas. Materialen die mooier worden met de jaren en passen bij het ambacht.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
