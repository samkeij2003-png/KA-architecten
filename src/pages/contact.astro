---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact — KA.architecten · Tilburg"
  description="Neem contact op met KA.architecten. Architect Peter Keijsers, Ankeveenstraat 44, Tilburg."
>
  <section class="section" style="padding-top: clamp(28px, 3vw, 44px); padding-bottom: clamp(40px, 6vw, 80px);">
    <div class="container">
      <div class="contact-grid">
        <!-- Linker kolom: titel + gegevens -->
        <div class="contact-info">
          <p class="eyebrow">Contact</p>
          <h1 style="margin-top: 8px; margin-bottom: 32px;">Neem contact op.</h1>

          <p class="eyebrow" style="margin-bottom: 8px;">Adres</p>
          <p style="font-size: 16px; line-height: 1.8; color: var(--ink-soft);">
            KA.architecten<br />
            Ankeveenstraat 44<br />
            5036 CB Tilburg
          </p>

          <p class="eyebrow" style="margin: 28px 0 8px;">Telefoon</p>
          <p><a href="tel:+31621231821" style="font-size: 16px; color: var(--ink-soft);">06 21 23 18 21</a></p>

          <p class="eyebrow" style="margin: 28px 0 8px;">E-mail</p>
          <p><a href="mailto:p.keijsers@ka-architecten.nl" style="font-size: 16px; color: var(--ink-soft);">p.keijsers@ka-architecten.nl</a></p>
        </div>

        <!-- Rechter kolom: formulier -->
        <div class="contact-form-wrap">
          <form id="contact-form" novalidate>
            <div class="form-row">
              <label for="naam">Naam</label>
              <input id="naam" name="naam" type="text" required placeholder="Uw naam" />
            </div>
            <div class="form-row">
              <label for="email">E-mail</label>
              <input id="email" name="email" type="email" required placeholder="Uw e-mailadres" />
            </div>
            <div class="form-row">
              <label for="onderwerp">Onderwerp</label>
              <select id="onderwerp" name="onderwerp">
                <option>Nieuwbouwwoning</option>
                <option>Verbouwing of uitbreiding</option>
                <option>Utiliteitsbouw</option>
                <option>Anders</option>
              </select>
            </div>
            <div class="form-row">
              <label for="bericht">Bericht</label>
              <textarea id="bericht" name="bericht" rows="4" required placeholder="Vertel kort over uw plek en wensen"></textarea>
            </div>
            <button type="submit" class="btn">Verzenden</button>
          </form>
          <p id="contact-thanks" style="display:none; padding-top: 20px;">
            Bedankt voor uw bericht. Peter neemt zo spoedig mogelijk contact met u op.
          </p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.8fr;
    gap: clamp(40px, 6vw, 96px);
    align-items: start;
  }

  .contact-form-wrap {
    border: 1px solid var(--hairline);
    padding: clamp(24px, 3vw, 40px);
    background: var(--bg);
  }

  @media (max-width: 720px) {
    .contact-grid { grid-template-columns: 1fr; }
  }
</style>
