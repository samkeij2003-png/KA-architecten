---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { projects } from '../../data/projects';
import { pub } from '../../utils/asset';
import { getImg } from '../../utils/images';

const coverImages = await Promise.all(projects.map(p => getImg(p.cover)));
---

<BaseLayout
  title="Projecten — KA.architecten · Architect Tilburg"
  description="Een selectie van projecten van Peter Keijsers — woningen, verbouwingen, utiliteitsbouw en woningbouw in Tilburg, Brabant en daarbuiten."
  ogImage="https://www.ka-architecten.nl/images/zeist-2.jpg"
>
  <section class="section" style="padding-top: clamp(24px, 3vw, 40px); padding-bottom: 20px;">
    <div class="container">
      <p class="eyebrow">Projecten</p>
      <h1 style="margin-top: 8px; max-width: 22ch;">Architectprojecten in Tilburg, Brabant en daarbuiten.</h1>
    </div>
  </section>

  <section class="section" style="padding-top: 24px;">
    <div class="container projects-layout">
      <aside class="projects-sidebar" role="tablist" aria-label="Filteren op type">
        <button class="filter-btn active" data-filter="alle">Alle</button>
        <button class="filter-btn" data-filter="particuliere">Woningen</button>
        <button class="filter-btn" data-filter="utiliteitsbouw">Utiliteitsbouw</button>
        <button class="filter-btn" data-filter="woningbouw">Woningbouw</button>
      </aside>
      <div id="projects-grid" class="projects-grid">
        {projects.map((p, i) => (
          <a class="project-card" href={pub(`/projecten/${p.slug}`)} data-type={p.type.toLowerCase()} aria-label={`Project: ${p.title}, ${p.location}`} style={`--i: ${i};`}>
            <div class="project-media">
              <Image
                src={coverImages[i]}
                alt={`${p.title}, ${p.location}`}
                loading="lazy"
                width={800}
                format="webp"
                quality={85}
              />
              <div class="project-overlay">
                <span class="name">{p.title}</span>
                <span class="loc">{p.location}{p.status === 'In uitvoering' ? ' · in uitvoering' : ''}</span>
              </div>
            </div>
            <div class="project-meta">
              <span class="name">{p.title}</span>
              <span class="loc">{p.location}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <script>
    const filterBtns = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
    const cards = document.querySelectorAll<HTMLElement>('.project-card[data-type]');

    function applyFilter(filter: string) {
      // Fade all visible cards out first
      cards.forEach(c => {
        if (c.style.display !== 'none') {
          c.style.transition = 'opacity .15s, transform .15s';
          c.style.opacity = '0';
          c.style.transform = 'translateY(6px)';
        }
      });
      setTimeout(() => {
        let vi = 0;
        cards.forEach(card => {
          const type = card.getAttribute('data-type') ?? '';
          const show = filter === 'alle' || type.includes(filter);
          card.style.transition = '';
          card.style.opacity = '';
          card.style.transform = '';
          if (show) {
            card.style.display = '';
            card.style.setProperty('--i', String(vi++));
            // Re-trigger stagger animation
            card.style.animation = 'none';
            card.offsetHeight; // reflow
            card.style.animation = '';
          } else {
            card.style.display = 'none';
          }
        });
      }, 170);
    }

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        applyFilter(btn.getAttribute('data-filter') ?? 'alle');
      });
    });
  </script>
</BaseLayout>
