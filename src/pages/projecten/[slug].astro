---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { projects } from '../../data/projects';
import { pub } from '../../utils/asset';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return projects.map(p => ({ params: { slug: p.slug }, props: { project: p } }));
};

const { project } = Astro.props;
const idx = projects.findIndex(p => p.slug === project.slug);
const prev = idx > 0 ? projects[idx - 1] : null;
const next = idx < projects.length - 1 ? projects[idx + 1] : null;

const imagesJson = JSON.stringify(project.images.map(p => pub(p)));
---

<BaseLayout
  title={`${project.title} · ${project.location} — KA.architecten`}
  description={project.intro}
  ogImage={`https://www.ka-architecten.nl${project.cover}`}
  canonical={`https://www.ka-architecten.nl/projecten/${project.slug}`}
>
  <script type="application/ld+json" slot="head">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CreativeWork",
    "name": project.title,
    "description": project.intro,
    "image": `https://www.ka-architecten.nl${project.cover}`,
    "creator": { "@type": "Person", "name": "Peter Keijsers" },
    "publisher": { "@type": "Organization", "name": "KA.architecten" },
    "locationCreated": {
      "@type": "Place",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": project.location,
        "addressRegion": project.province,
        "addressCountry": "NL"
      }
    },
    "dateCreated": project.year,
  })}</script>

  <article>
    <!-- HERO: coverfoto full-bleed met titel overlay -->
    <section class="project-hero">
      <img src={pub(project.cover)} alt={`${project.title}, ${project.location}`} fetchpriority="high" />
      <div class="project-hero-veil"></div>
      <a href={pub('/projecten')} class="project-back"><span class="arrow">←</span>Projecten</a>
      <div class="project-hero-content">
        <p class="eyebrow" style="color: rgba(246,245,241,0.65);">{project.location}</p>
        <h1 style="color: #F6F5F1; margin-top: 10px; max-width: 22ch;">{project.title}</h1>
      </div>
    </section>

    <!-- INTRO + BODY + FACTS -->
    <section class="section" style="padding-top: 48px; padding-bottom: 40px;">
      <div class="container">
        <p class="lead" style="margin-bottom: clamp(32px, 4vw, 56px); max-width: 60ch;">{project.intro}</p>
        <div class="detail-grid">
          <div class="body-text" style="font-size: 17px;">
            {project.body.map(p => <p>{p}</p>)}
          </div>
          <div class="facts">
            <dl>
              <dt>Locatie</dt><dd>{project.location}, {project.province}</dd>
              <dt>Type</dt><dd>{project.type}</dd>
              <dt>Status</dt><dd>{project.status} · {project.year}</dd>
              <dt>Architect</dt><dd>{project.architect}</dd>
              {project.aannemer && <><dt>Aannemer</dt><dd>{project.aannemer}</dd></>}
              {project.constructeur && <><dt>Constructeur</dt><dd>{project.constructeur}</dd></>}
              {project.fotograaf && <><dt>Fotografie</dt><dd>{project.fotograaf}</dd></>}
            </dl>
          </div>
        </div>
      </div>
    </section>

    <!-- GALERIJ -->
    {project.images.length > 1 && (
      <section class="section hairline" style="padding-top: 40px;">
        <div class="container">
          <p class="eyebrow mb-md">
            Beelden
            <span style="color: var(--hairline); margin: 0 8px;">·</span>
            <span style="font-size: 10px; letter-spacing: 0.12em; color: var(--stone);">klik om te vergroten</span>
          </p>
          <div
            class="gallery"
            data-lightbox-group={imagesJson}
            data-lightbox-caption={project.title}
          >
            {project.images.map((src, i) => {
              const cls = i === 0 ? 'g-wide' : 'g-half';
              return (
                <figure class={cls}>
                  <img src={pub(src)} alt={`${project.title} (${i + 1}/${project.images.length})`} loading="lazy" />
                </figure>
              );
            })}
          </div>
        </div>
      </section>
    )}
  </article>

  <!-- PAGER -->
  <section class="section hairline">
    <div class="container">
      <div class="pager">
        {prev ? (
          <a href={pub(`/projecten/${prev.slug}`)}>
            <span class="label">← Vorig project</span>
            <span class="title">{prev.title}</span>
          </a>
        ) : <div />}
        {next ? (
          <a class="next" href={pub(`/projecten/${next.slug}`)}>
            <span class="label">Volgend project →</span>
            <span class="title">{next.title}</span>
          </a>
        ) : <div />}
      </div>
      <p style="margin-top: 40px;">
        <a class="link-arrow" href={pub('/contact')}>Plan een vrijblijvend gesprek →</a>
      </p>
    </div>
  </section>
</BaseLayout>
