---
import { pub } from '../utils/asset';

const navLinks = [
  { href: '/projecten', label: 'Projecten' },
  { href: '/bureau', label: 'Bureau' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <nav class="nav" aria-label="Hoofdmenu">
    <a class="logo" href={pub('/')} aria-label="KA.architecten — home">
      <span class="amark">KA</span><span class="dot">.</span>architecten
    </a>
    <button class="nav-toggle" aria-label="Menu openen" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
    <div class="nav-links" role="menu">
      {navLinks.map(({ href, label }) => (
        <a
          href={pub(href)}
          class:list={[{ 'is-active': currentPath.startsWith(pub(href)) }]}
        >
          {label}
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const links = document.querySelector<HTMLElement>('.nav-links');

  toggle?.addEventListener('click', () => {
    const open = links?.classList.toggle('open');
    toggle.classList.toggle('is-open', open);
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Menu sluiten' : 'Menu openen');
  });

  // sluit menu bij navigatie naar een link
  links?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      links.classList.remove('open');
      toggle?.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
      toggle?.setAttribute('aria-label', 'Menu openen');
    });
  });
</script>
