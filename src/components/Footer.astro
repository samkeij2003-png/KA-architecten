---
import { pub } from '../utils/asset';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-grid">
    <div>
      <h4>KA.architecten</h4>
      <p style="color: var(--ink-soft); font-size: 13px; line-height: 1.7; margin: 0 0 14px; max-width: 32ch;">
        Architectuurbureau voor woningontwerp, verbouwing en utiliteitsbouw.
        Werkzaam in Tilburg en heel Noord-Brabant.
      </p>
      <p style="font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color: var(--stone);">Architect Peter Keijsers</p>
      <div style="margin-top: 16px; display: flex; gap: 16px;">
        <a href="https://www.instagram.com/ka.architecten" target="_blank" rel="noopener noreferrer" style="font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--stone);">Instagram</a>
        <a href="https://www.linkedin.com/in/peter-keijsers-07016813" target="_blank" rel="noopener noreferrer" style="font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--stone);">LinkedIn</a>
      </div>
    </div>
    <div>
      <h4>Bekijken</h4>
      <a href={pub('/projecten')}>Projecten</a>
      <a href={pub('/bureau')}>Bureau</a>
      <a href={pub('/nieuws')}>Nieuws</a>
    </div>
    <div>
      <h4>Contact</h4>
      <a href="https://maps.google.com/?q=Ankeveenstraat+44+Tilburg" target="_blank" rel="noopener">
        Ankeveenstraat 44<br />5036 CB Tilburg
      </a>
      <a href="tel:+31621231821">06 21 23 18 21</a>
      <a href="mailto:p.keijsers@ka-architecten.nl">p.keijsers@ka-architecten.nl</a>
    </div>
  </div>
  <div class="footer-base">
    <span>KA.architecten · Architect Peter Keijsers · Tilburg</span>
    <span>© {year}</span>
  </div>
</footer>
