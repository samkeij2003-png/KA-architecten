# Google Analytics 4 — Measurement ID
# Maak een GA4 property aan op analytics.google.com
# Kopieer dit bestand naar .env en vul het ID in (begint met G-)
PUBLIC_GA_ID=G-XXXXXXXXXX

# Payload CMS — REST API
# Lokaal: http://localhost:3001 | Productie: https://cms.jouwdomein.nl
CMS_URL=http://localhost:3001
# Slug van de site in het CMS (zie Sites-collectie in Payload admin)
CMS_SITE_SLUG=ka-architecten
